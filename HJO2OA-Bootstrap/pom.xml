        </dependency>
        <dependency>
            <groupId>com.hjo2oa</groupId>
            <artifactId>HJO2OA-Timezone</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>com.hjo2oa</groupId>
            <artifactId>HJO2OA-Tenant</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>com.hjo2oa</groupId>
            <artifactId>HJO2OA-Scheduler</artifactId>
