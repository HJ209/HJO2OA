            <groupId>com.hjo2oa</groupId>
            <artifactId>HJO2OA-EventBus</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>com.hjo2oa</groupId>
            <artifactId>HJO2OA-Audit</artifactId>
