                    <artifactId>HJO2OA-ContentPermission</artifactId>
                    <version>${project.version}</version>
                </dependency>
                <dependency>
                    <groupId>com.hjo2oa</groupId>
                    <artifactId>HJO2OA-ContentSearch</artifactId>
                    <version>${project.version}</version>
                </dependency>
